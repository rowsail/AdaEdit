# Pinned external components fetched at AppImage build time (NOT committed).
# Bump a version + sha256 here to update the bundle; the repo stays tiny.

# The ESP32-S3 Ada SDK (Alire-free build, runtime source packs, vendored
# dynconfig + xtensa-only bb-runtimes).  Fetched as a tarball of a tagged commit.
SDK_REPO="https://github.com/rowsail/ada_esp32s3"
SDK_REF="main"                     # pin to a tag/commit for releases
SDK_SHA256=""                       # fill when pinning a tag

# GNAT toolchains -- the same crates `alr toolchain --select` installs.  At build
# time we let `alr` fetch them into a temp config and copy them into the bundle
# (so we don't re-host AdaCore's binaries).  Pin the crate versions:
GNAT_XTENSA_CRATE="gnat_xtensa_esp32_elf"
GNAT_NATIVE_CRATE="gnat_native"
GPRBUILD_CRATE="gprbuild"
TOOLCHAIN_GNAT_VERSION="15.2.1"
TOOLCHAIN_GPRBUILD_VERSION="25.0.1"

# ada_language_server (semantic features).  AdaCore release tarball.
ALS_VERSION="2026.2.202604091"
ALS_URL="https://github.com/AdaCore/ada_language_server/releases/download/${ALS_VERSION}/als-${ALS_VERSION}-linux-x64.tar.gz"
ALS_SHA256=""                       # fill when pinning

# Alire (alr) -- build-time toolchain fetcher only (not bundled).
ALR_VERSION="2.1.1"
ALR_URL="https://github.com/alire-project/alire/releases/download/v${ALR_VERSION}/alr-${ALR_VERSION}-bin-x86_64-linux.zip"

# OpenOCD + xtensa esp gdb are fetched by the SDK's own tools/get-*.sh at build
# time (already pinned inside the SDK), so no URLs are needed here.
